{"version":3,"term":{"cols":80,"rows":24},"timestamp":1784617634,"command":"PYTHONPATH=/Users/javadtaghia/gitlab/aetnamem /opt/homebrew/bin/python3.12 /private/tmp/claude-501/-Users-javadtaghia-gitlab-aetnamem/113661c4-d84c-415f-9788-b44844ab3229/scratchpad/etd-demo/etd_walkthrough.py","env":{"SHELL":"/bin/zsh"}}
[0.143, "o", "\r\n\u001b[1m================ AETNAMEM EVIDENCE-TO-DECISION WORKFLOW ================\u001b[0m\r\n"]
[0.905, "o", "\u001b[2mNamespace: demo-f0fb265d\u001b[0m\r\n\u001b[2mPrincipals: dr-chair (chair), consumer-representative (voter),\r\n\u001b[2m            hospital-executive (approver)\u001b[0m\r\n"]
[0.033, "o", "\r\n\u001b[1m[1]\u001b[0m Chair opens a case on the clinical EtD template.\r\n"]
[0.911, "o", "\u001b[32m✓\u001b[0m case dec_e3c9407d7509493091d5db55c6459630 created\r\n"]
[0.363, "o", "\r\n\u001b[1m[2]\u001b[0m Chair seats the panel: a voter and an institutional approver.\r\n"]
[0.909, "o", "\u001b[32m✓\u001b[0m panel seated: chair, voter, approver\r\n"]
[0.365, "o", "\r\n\u001b[1m[3]\u001b[0m Evidence bundle submitted, with its own trust tier and certainty rating.\r\n"]
[0.907, "o", "\u001b[32m✓\u001b[0m evidence revision drv_86c833975d074ac4826a98bbdfba5645 (certainty: moderate)\r\n"]
[0.361, "o", "\r\n\u001b[1m[4]\u001b[0m Chair records a feasibility judgment, linked to that evidence.\r\n"]
[0.910, "o", "\u001b[32m✓\u001b[0m assessment revision drv_87e6c56ed99a4acfa55ebdda147a01b5 -> supports evidence\r\n"]
[0.362, "o", "\r\n\u001b[1m[5]\u001b[0m Recommendation drafted, linked to the assessment that supports it.\r\n"]
[0.907, "o", "\u001b[32m✓\u001b[0m recommendation revision drv_0e835098905048cfb8595286a7899fa8\r\n"]
[0.365, "o", "\r\n\u001b[1m[6]\u001b[0m Chair opens a hidden-until-close ballot on the recommendation.\r\n"]
[0.907, "o", "\u001b[32m✓\u001b[0m ballot bal_84b8804f31394576a6bba96d5627698b open (visibility: hidden_until_close)\r\n"]
[0.364, "o", "\r\n\u001b[1m[7]\u001b[0m Chair and voter cast independent votes. Neither sees the other's yet.\r\n"]
[0.908, "o", "\u001b[32m✓\u001b[0m 2 votes cast, both hidden until close\r\n"]
[0.364, "o", "\r\n\u001b[1m[8]\u001b[0m Ballot closes. Outcome is computed deterministically from the policy.\r\n"]
[0.904, "o", "\u001b[32m✓\u001b[0m outcome out_78a8e8603be64f4aaf3da6d1a86ccb3e: passed\r\n"]
[0.365, "o", "\r\n\u001b[1m[9]\u001b[0m Chair adopts the recommendation on the strength of that outcome.\r\n"]
[0.908, "o", "\u001b[32m✓\u001b[0m adoption adp_488f9918b8574812b39e00b064c8b37d\r\n"]
[0.365, "o", "\r\n\u001b[1m[10]\u001b[0m Implementation plan drafted, linked to the adopted recommendation.\r\n"]
[0.902, "o", "\u001b[32m✓\u001b[0m plan revision drv_d01117cd92f14c5597e42ae4dd487c6f\r\n"]
[0.365, "o", "\r\n\u001b[1m[11]\u001b[0m Institutional approver signs off on resourcing the plan.\r\n"]
[0.907, "o", "\u001b[32m✓\u001b[0m approval apr_e510c3d023394c25a6e6dbf29f90edf6 (approver: hospital-executive)\r\n"]
[0.360, "o", "\r\n\u001b[1m[12]\u001b[0m Chair grants a SCOPED authorization -- exact adapter, operation, resource.\r\n"]
[0.905, "o", "\u001b[32m✓\u001b[0m authorization aut_692e4c8c2e7a439ea2bfce61ddfcd43e scoped to filesystem.write_text on approved-change.md\r\n"]
[0.360, "o", "\u001b[2mThis authorization -- not the panel vote itself -- is what a guarded\u001b[0m\r\n\u001b[2maction engine will revalidate before it will stage or execute anything.\u001b[0m\r\n\r\n\u001b[1m[13]\u001b[0m Chair exports the full case as a canonical, hash-linked bundle.\r\n"]
[0.904, "o", "\u001b[32m✓\u001b[0m bundle exported: 4 linked record(s)\r\n"]
[0.362, "o", "\r\n\u001b[1m================ DONE ================\u001b[0m\r\n"]
[0.905, "o", "Every judgment, vote, adoption, approval, and authorization above is\r\nits own auditable transition -- recommendation, institutional approval,\r\nand change authorization are kept distinct, on purpose.\r\n"]
[0.031, "x", "0"]
